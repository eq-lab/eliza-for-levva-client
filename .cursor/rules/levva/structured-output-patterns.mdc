## 📝 **Complete Example**

### **1. Define Schema**

```typescript
// src/prompts/suggest/schema.ts
import { z } from "zod";

export const depositSuggestionSchema = z.object({
  thought: z
    .string()
    .describe(
      "Your analysis of the user's deposit intent and what parameters are missing"
    ),
  suggestions: z
    .array(
      z.object({
        label: z
          .string()
          .describe(
            "Specific, actionable label (2-5 words) like 'Deposit 100 USDC' or 'Safe strategy'"
          ),
        text: z
          .string()
          .describe(
            "Complete user message like 'I want to deposit 100 USDC into the safe strategy'"
          ),
      })
    )
    .min(3)
    .max(6)
    .describe("Array of 3-6 suggestion objects"),
});

export type DepositSuggestionResult = z.infer<typeof depositSuggestionSchema>;
```

### **2. Use in Model Call**

```typescript
// src/evaluators/suggestions.ts
import { ModelType } from "@elizaos/core";
import { zodJsonSchema } from "../prompts/util";
import {
  depositSuggestionSchema,
  type DepositSuggestionResult,
} from "../prompts/suggest/schema";

async function generateDepositSuggestions(
  runtime: IAgentRuntime,
  prompt: string
): Promise<DepositSuggestionResult> {
  const result: DepositSuggestionResult = await runtime.useModel(
    ModelType.OBJECT_SMALL,
    {
      prompt,
      schema: zodJsonSchema(depositSuggestionSchema),
      temperature: 0,
    }
  );

  return result;
}
```

### **3. Generate Prompt with Output Format**

```typescript
// src/prompts/suggest/deposit-intent.ts
import { formatZodOutput } from "../util";
import { depositSuggestionSchema } from "./schema";

export function generateDepositPrompt(params: Params): string {
  return `<task>
Generate deposit suggestions for the user
</task>

<context>
${params.context}
</context>

<instructions>
Generate 3-5 specific, actionable suggestions.
Use ACTUAL amounts and strategy names from context.
</instructions>

<output>
${formatZodOutput(depositSuggestionSchema)}

CRITICAL REQUIREMENTS:
- Each suggestion MUST have BOTH "label" AND "text" fields
- Labels must be SPECIFIC (e.g., "Deposit 100 USDC", NOT "Edit amount")
- Text must be complete user messages
</output>`;
}
```

