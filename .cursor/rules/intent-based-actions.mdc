# Intent-Based Action Resolution System

## 📋 Cross-References
This file contains the **intent-based action system** patterns. Related files:
- `elizaos-patterns.mdc` - Core ElizaOS framework patterns
- `action-patterns.mdc` - Action handler return values and validation patterns
- `position-management.mdc` - Position management specific business logic
- `debugging-patterns.mdc` - Troubleshooting intent-related issues

## Problem: Action Resolution Conflicts
When multiple actions have similar validation logic (e.g., both `withdraw` and `position` actions checking if user has positions), the framework may select the wrong action, leading to incorrect behavior and poor user experience.

## Solution: Persistent Intent Tracking
Instead of separate actions competing for resolution, use a unified action system with persistent intent tracking:

### Core Concept
1. **Intent Detection**: When user expresses intent (e.g., "I want to withdraw"), detect and classify the intent type
2. **Intent ID Generation**: Generate a unique `intent_id` that persists across the conversation flow
3. **Intent Hierarchy**: Support parent-child intent relationships and cross-action coordination
4. **Unified Actions**: Use domain-specific actions (`POSITION_MANAGEMENT`, `SWAP_TOKENS`) that coordinate through intent system
5. **Context Preservation**: All subsequent messages and transactions are tagged with the `intent_id` for improved context tracking

### Implementation Pattern
```typescript
// Intent detection and ID generation
const detectIntent = (message: string): { type: IntentType; id: string } => {
  const messageText = message.toLowerCase();
  
  if (withdrawalKeywords.some(k => messageText.includes(k))) {
    return {
      type: 'WITHDRAW',
      id: `withdraw_${Date.now()}_${randomUUID().slice(0, 8)}`
    };
  }
  
  if (viewKeywords.some(k => messageText.includes(k))) {
    return {
      type: 'VIEW_POSITIONS',
      id: `view_${Date.now()}_${randomUUID().slice(0, 8)}`
    };
  }
  
  return { type: 'UNKNOWN', id: '' };
};

// Unified action with intent routing
export const positionManagementAction: Action = {
  name: "POSITION_MANAGEMENT",
  description: "Unified position management with intent-based routing",
  
  validate: async (runtime: IAgentRuntime, message: Memory) => {
    // Check for existing intent or detect new intent
    const existingIntent = await getActiveIntent(runtime, message);
    const detectedIntent = detectIntent(message.content.text);
    
    return existingIntent || detectedIntent.type !== 'UNKNOWN';
  },
  
  handler: async (runtime, message, state, options, callback) => {
    // Get or create intent context
    let intentContext = await getActiveIntent(runtime, message);
    
    if (!intentContext) {
      const detected = detectIntent(message.content.text);
      intentContext = {
        id: detected.id,
        type: detected.type,
        createdAt: Date.now(),
        userId: message.userId,
        channelId: message.channelId
      };
      
      await storeIntent(runtime, intentContext);
    }
    
    // Route to appropriate handler based on intent type
    switch (intentContext.type) {
      case 'WITHDRAW':
        return await handleWithdrawIntent(runtime, message, state, callback, intentContext);
      case 'VIEW_POSITIONS':
        return await handleViewIntent(runtime, message, state, callback, intentContext);
      default:
        return await handleUnknownIntent(runtime, message, state, callback);
    }
  }
};
```

## Intent Context Management with Hierarchy
```typescript
interface IntentContext {
  id: string;
  type: 'WITHDRAW' | 'INCREASE_POSITION' | 'VIEW_POSITIONS' | 'SWAP' | 'STRATEGY_SELECT';
  domain: 'POSITION_MANAGEMENT' | 'SWAP_TOKENS' | 'STRATEGY_SELECTION';
  createdAt: number;
  userId: string;
  channelId: string;
  metadata?: Record<string, any>;
  status: 'ACTIVE' | 'COMPLETED' | 'CANCELLED' | 'PAUSED';
  
  // Intent hierarchy and relationships
  parentIntentId?: string;  // For child intents (e.g., SWAP initiated from INCREASE_POSITION)
  childIntentIds?: string[]; // For parent intents tracking their children
  initiatedBy?: string;     // Parent intent that triggered this intent
  
  // Cross-intent data passing
  inheritedData?: Record<string, any>; // Data passed from parent intent
  returnData?: Record<string, any>;    // Data to return to parent when completed
}

// Intent relationship rules
const INTENT_RELATIONSHIPS = {
  // Conflicting intents within same domain (cancel each other)
  CONFLICTING_PAIRS: [
    ['WITHDRAW', 'INCREASE_POSITION'], // Can't withdraw and increase simultaneously
  ],
  
  // Parent-child relationships (child intents can be spawned from parent)
  PARENT_CHILD_ALLOWED: {
    'INCREASE_POSITION': ['SWAP'], // Can initiate swap to get assets for position increase
    'STRATEGY_SELECT': ['SWAP'],   // Can swap to get required assets for strategy
  } as Record<string, string[]>,
  
  // Cross-domain isolation (intents in different domains don't see each other's context)
  DOMAIN_ISOLATION: true,
};

// Enhanced intent management
class IntentManager {
  static async createIntent(
    runtime: IAgentRuntime, 
    intentData: Omit<IntentContext, 'id' | 'createdAt' | 'status'>,
    parentIntent?: IntentContext
  ): Promise<IntentContext> {
    const intent: IntentContext = {
      ...intentData,
      id: `${intentData.type.toLowerCase()}_${Date.now()}_${randomUUID().slice(0, 8)}`,
      createdAt: Date.now(),
      status: 'ACTIVE',
      parentIntentId: parentIntent?.id,
      inheritedData: parentIntent?.returnData || {},
    };
    
    // Handle conflicting intents in same domain
    if (intentData.domain === 'POSITION_MANAGEMENT') {
      await this.handlePositionManagementConflicts(runtime, intent, intentData.userId, intentData.channelId);
    }
    
    // Update parent intent if this is a child
    if (parentIntent) {
      parentIntent.childIntentIds = [...(parentIntent.childIntentIds || []), intent.id];
      parentIntent.status = 'PAUSED'; // Pause parent while child is active
      await this.storeIntent(runtime, parentIntent);
    }
    
    await this.storeIntent(runtime, intent);
    return intent;
  }
  
  static async handlePositionManagementConflicts(
    runtime: IAgentRuntime, 
    newIntent: IntentContext, 
    userId: string, 
    channelId: string
  ) {
    const existingIntent = await this.getActiveIntentByDomain(runtime, userId, channelId, 'POSITION_MANAGEMENT');
    
    if (existingIntent) {
      // Check for conflicts
      const isConflicting = INTENT_RELATIONSHIPS.CONFLICTING_PAIRS.some(([type1, type2]) => 
        (existingIntent.type === type1 && newIntent.type === type2) ||
        (existingIntent.type === type2 && newIntent.type === type1)
      );
      
      if (isConflicting) {
        // Cancel existing conflicting intent
        existingIntent.status = 'CANCELLED';
        await this.storeIntent(runtime, existingIntent);
        
        runtime.logger.info(`Cancelled conflicting intent ${existingIntent.id} (${existingIntent.type}) for new intent ${newIntent.type}`);
      }
    }
  }
  
  static async getActiveIntentByDomain(
    runtime: IAgentRuntime, 
    userId: string, 
    channelId: string, 
    domain: string
  ): Promise<IntentContext | null> {
    const cacheKey = `intent_${domain}_${userId}_${channelId}`;
    return await runtime.getCache<IntentContext>(cacheKey);
  }
  
  static async storeIntent(runtime: IAgentRuntime, intent: IntentContext) {
    // Store by domain for conflict detection
    const domainCacheKey = `intent_${intent.domain}_${intent.userId}_${intent.channelId}`;
    await runtime.setCache(domainCacheKey, intent, 30 * 60 * 1000); // 30 minutes TTL
    
    // Store by ID for direct lookup
    const idCacheKey = `intent_id_${intent.id}`;
    await runtime.setCache(idCacheKey, intent, 30 * 60 * 1000);
  }
  
  static async completeChildIntent(
    runtime: IAgentRuntime, 
    childIntent: IntentContext, 
    returnData?: Record<string, any>
  ) {
    childIntent.status = 'COMPLETED';
    childIntent.returnData = returnData;
    await this.storeIntent(runtime, childIntent);
    
    // Resume parent intent if exists
    if (childIntent.parentIntentId) {
      const parentIntent = await runtime.getCache<IntentContext>(`intent_id_${childIntent.parentIntentId}`);
      if (parentIntent) {
        parentIntent.status = 'ACTIVE';
        parentIntent.inheritedData = { ...parentIntent.inheritedData, ...returnData };
        
        // Remove completed child from tracking
        parentIntent.childIntentIds = parentIntent.childIntentIds?.filter(id => id !== childIntent.id) || [];
        
        await this.storeIntent(runtime, parentIntent);
      }
    }
  }
}
```

