## 🔗 **Service Integration Pattern**

```typescript
import { Service, IAgentRuntime } from "@elizaos/core";
import { TokenServiceComponent } from "./token";
import { WalletServiceComponent } from "./wallet";

export class MainService extends Service {
  // Make runtime public for cache utilities
  declare public readonly runtime: IAgentRuntime;

  // Compose ServiceComponents
  public readonly token: TokenServiceComponent;
  public readonly wallet: WalletServiceComponent;

  constructor(runtime: IAgentRuntime) {
    super(runtime);
    
    // Initialize components
    this.token = new TokenServiceComponent(runtime);
    this.wallet = new WalletServiceComponent(runtime);
  }

  async stop() {
    // Cleanup components
    this.token.cleanup();
    this.wallet.cleanup();
  }

  // Backward compatibility delegation
  /** @deprecated Use this.token.getToken() directly instead */
  getToken = (...args) => this.token.getToken(...args);
}
```

---

## 🎯 **Naming Conventions**

- **Components**: `[Domain]ServiceComponent` (e.g., `TokenServiceComponent`)
- **Files**: `[domain].ts` (e.g., `token.ts`, `wallet.ts`)
- **Export**: Named export of the ServiceComponent class

---

## 📦 **Cache Integration**

```typescript
import { createTimedCache, createPermanentCache } from "./cache-util";

export class MyServiceComponent {
  runtime: IAgentRuntime;
  
  constructor(runtime: IAgentRuntime) {
    this.runtime = runtime;
  }

  private getCacheKey = (param: string) => `my-component:${param}`;

  // ✅ Correct - pass component instance
  cachedMethod = createTimedCache(
    this,        // Component instance (has runtime property)
    300000,      // TTL
    this.actualMethod,
    this.getCacheKey
  );
}
```

**Key Points**:
- Always pass component instance (`this`) to cache utilities
- Cache utilities expect objects with `runtime` property
- Use component-specific cache key prefixes

