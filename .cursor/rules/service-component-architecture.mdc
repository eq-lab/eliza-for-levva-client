## 🚨 **Common Anti-Patterns**

### **1. Extending Service**
```typescript
// ❌ Wrong
export class TokenServiceComponent extends Service { }

// ✅ Correct
export class TokenServiceComponent { }
```

### **2. Wrong Cache Usage**
```typescript
// ❌ Wrong - passing runtime instead of component
createTimedCache(this.runtime, ttl, fn, keyFn);

// ✅ Correct - pass component instance
createTimedCache(this, ttl, fn, keyFn);
```

### **3. Private Runtime Constructor**
```typescript
// ❌ Wrong - doesn't work with cache utilities
constructor(private runtime: IAgentRuntime) {}

// ✅ Correct - explicit property
runtime: IAgentRuntime;
constructor(runtime: IAgentRuntime) {
  this.runtime = runtime;
}
```

### **4. Direct Logger Import**
```typescript
// ❌ Wrong
import { logger } from "@elizaos/core";
logger.info("Message");

// ✅ Correct
this.runtime.logger.info("Message");
```

### **5. Missing Cleanup**
```typescript
// ❌ Wrong - memory leak
export class ComponentWithTimers {
  private interval = setInterval(() => {}, 1000);
}

// ✅ Correct
export class ComponentWithTimers {
  private interval = setInterval(() => {}, 1000);
  
  cleanup() {
    clearInterval(this.interval);
  }
}
```

### **6. Rebuilding Component Data Structures**
```typescript
// ❌ Wrong - Rebuilding data that already exists in component
async function generateSuggestions(service: LevvaService) {
  // getWalletAssets already calls getAvailableTokens which populates tokenMap
  const walletAssets = await service.wallet.getWalletAssets({ address, chainId });
  
  // BAD: Rebuilding tokenMap from component's tokenMap!
  const tokenMap: Record<string, TokenInfo> = {};
  service.token.tokenMap.forEach((token, key) => {
    if (token && key.startsWith(`${chainId}:`)) {
      const address = key.split(":")[1];
      tokenMap[address.toLowerCase()] = {
        symbol: token.symbol,
        address: token.address,
      };
    }
  });
  
  // Pass rebuilt map
  return generatePrompt({ walletAssets, tokenMap });
}

// ✅ Correct - Pass component's data structure directly
async function generateSuggestions(service: LevvaService) {
  const walletAssets = await service.wallet.getWalletAssets({ address, chainId });
  
  // GOOD: Pass component's tokenMap directly!
  return generatePrompt({ 
    walletAssets, 
    tokenMap: service.token.tokenMap, // Direct reference
    chainId 
  });
}

// In the prompt generation function:
function generatePrompt(params: {
  walletAssets: BalanceData[];
  tokenMap: Map<`${number}:0x${string}`, TokenInfo>; // Accept component's Map type
  chainId: number;
}) {
  // Helper for lookups
  const getToken = (address: string) => {
    return params.tokenMap.get(`${chainId}:${address}` as `${number}:0x${string}`);
  };
  
  // Use helper for O(1) lookups
  const token = getToken(asset.token);
  const symbol = token?.symbol || 'UNKNOWN';
}
```

**Why This Matters:**
- ❌ **Performance**: Rebuilding creates O(n) iteration + object creation overhead
- ❌ **Memory**: Duplicates data already in memory
- ❌ **Maintenance**: Two versions of same data to keep in sync
- ✅ **Single Source of Truth**: Component owns and maintains the data structure
- ✅ **Direct Access**: O(1) Map lookups instead of object property access
- ✅ **Type Safety**: Preserve proper Map types throughout the call chain

