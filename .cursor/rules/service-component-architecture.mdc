## 🧪 **Testing Patterns**

### **ServiceComponent Testing**
```typescript
import { describe, it, expect, beforeEach, afterEach } from "vitest";
import { createMockRuntime } from "../test-utils";
import { TokenServiceComponent } from "./token";

describe("TokenServiceComponent", () => {
  let component: TokenServiceComponent;
  let mockRuntime: IAgentRuntime;

  beforeEach(() => {
    mockRuntime = createMockRuntime();
    component = new TokenServiceComponent(mockRuntime);
  });

  it("should process token data", async () => {
    const result = await component.getTokenData("0x123", 1);
    expect(result).toBeDefined();
  });

  afterEach(() => {
    component.cleanup();
  });
});
```

### **Service Integration Testing**
```typescript
describe("MainService with ServiceComponents", () => {
  it("should integrate ServiceComponents correctly", () => {
    const service = new MainService(mockRuntime);
    
    // Test ServiceComponent access
    expect(service.token).toBeInstanceOf(TokenServiceComponent);
    expect(service.wallet).toBeInstanceOf(WalletServiceComponent);
    
    // Test deprecated methods still work
    expect(service.getToken).toBeDefined();
  });
});
```

