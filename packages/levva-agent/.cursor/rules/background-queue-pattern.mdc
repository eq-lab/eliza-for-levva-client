# BackgroundQueue Pattern for ServiceComponents

## 🎯 **When to Use BackgroundQueue**

Use `BackgroundQueue` when your ServiceComponent needs:
- Async operations with promise deduplication
- Task cancellation capabilities
- Event-driven background processing
- Queue management for concurrent operations

**Examples**: Balance fetching, news scraping, data synchronization

---

## 🏗️ **BackgroundQueue ServiceComponent Template**

```typescript
import { IAgentRuntime } from @elizaos/core;
import { BackgroundQueue } from ./background-queue;
import { createTimedCache } from ./cache-util;

// Define the type for queue items
interface ComponentData {
  id: string;
  value: string;
  // ... other fields
}

export class [Name]ServiceComponent extends BackgroundQueue<ComponentData> {
  // Component-specific constants (optional)
  private ITEM_PREFIX = component-item:;

  constructor(runtime: IAgentRuntime) {
    super(runtime); // BackgroundQueue provides this.runtime
  }

  cleanup() {
    // Cleanup queue first
    this.cleanupQueue();
    
    this.runtime.logger.info([Name]ServiceComponent cleanup completed);
  }

  // Required: Implement abstract method from BackgroundQueue
  protected onBackgroundResolved = async (event: {
    id: string;
    value: ComponentData;
  }) => {
    // All events in this queue belong to this component's domain
    // No need for prefix checking - trust the architecture!
    await this.processResolvedItem(event.value);
  };

  // Helper to create consistent IDs
  private createItemId = (param: string) => {
    return `${this.ITEM_PREFIX}${param}`;
  };

  // Use inBackground for async operations
  async fetchData(param: string): Promise<ComponentData | undefined> {
    const id = this.createItemId(param);
    
    return this.inBackground(
      id,
      async () => {
        // Your async operation
        const data = await someAsyncOperation(param);
        return data;
      },
      15000 // Optional custom wait time
    );
  }

  // Can still use cached methods
  getCachedData = createTimedCache(
    this,
    300000,
    this.actualDataFetch,
    (param) => `cache-key:${param}`
  );

  private async processResolvedItem(data: ComponentData) {
    // Handle resolved background operations
    // e.g., save to database, emit events, etc.
  }
}
```

---

## ✅ **Key Principles**

### **1. Trust Your Architecture**
```typescript
// ✅ Correct - each component has dedicated queue
protected onBackgroundResolved = async (event: {
  id: string;
  value: ComponentData;
}) => {
  // All events belong to this component - no checking needed
  await this.handleData(event.value);
};

// ❌ Wrong - unnecessary defensive checks
protected onBackgroundResolved = async (event: {
  id: string;
  value: any;
}) => {
  if (this.isMyItemId(event.id)) { // Redundant!
    await this.handleData(event.value);
  } else {
    this.runtime.logger.warn(`Unknown event: ${event.id}`); // Never happens!
  }
};
```

### **2. Use Strong Typing**
```typescript
// ✅ Correct - strongly typed queue
export class MyComponent extends BackgroundQueue<MyDataType> {
  protected onBackgroundResolved = async (event: {
    id: string;
    value: MyDataType; // Type-safe!
  }) => {
    await this.handleData(event.value);
  };
}

// ❌ Wrong - loses type safety
export class MyComponent extends BackgroundQueue<any> {
  protected onBackgroundResolved = async (event: {
    id: string;
    value: any; // No type safety!
  }) => {
    await this.handleData(event.value);
  };
}
```

### **3. Avoid Unnecessary Wrappers**
```typescript
// ❌ Wrong - pointless indirection
private createItemId = (url: string) => {
  return getItemIdFromHelper(url); // Just calls another function!
};
const id = this.createItemId(url);

// ✅ Correct - use the helper directly
const id = getItemIdFromHelper(url);
```

