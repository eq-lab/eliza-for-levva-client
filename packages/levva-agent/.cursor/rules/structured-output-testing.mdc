## ✅ **What to Test**

### **❌ Don't Test**

- Zod schema validation (library is already tested)
- Whether LLM returns JSON (provider handles this)
- Schema structure compliance (that's Zod's job)

### **✅ Do Test**

1. **Business Requirements**: Count, constraints, required fields
2. **Content Quality**: Specific, not generic
3. **Data Usage**: Uses actual context data
4. **Determinism**: Same input → Same output (temperature 0)
5. **Integration**: Works with real data from services

---

## 📋 **Test Patterns**

### **Pattern 1: Business Requirements**

Test that output meets your business rules, not just schema structure.

```typescript
import { describe, it, expect } from vitest;
import { z } from zod;
import { generateStructured, OPENROUTER_MODELS } from ../utils/openrouter;

const depositSuggestionSchema = z.object({
  thought: z.string(),
  suggestions: z
    .array(
      z.object({
        label: z.string(),
        text: z.string(),
      })
    )
    .min(3)
    .max(6),
});

type DepositSuggestion = z.infer<typeof depositSuggestionSchema>;

describe(Deposit Suggestions, () => {
  it(should generate 3-6 suggestions as per business requirements, async () => {
    const walletAssets = [
      { token: 0x..., symbol: USDC, amount: 1000n * 10n ** 6n },
    ];
    const strategies = [{ id: 1, name: Safe Yield Strategy, risk: low }];

    const prompt = generateDepositPrompt({ walletAssets, strategies });

    // Use default small model for simple suggestion generation
    const result: DepositSuggestion = await generateStructured(
      depositSuggestionSchema,
      prompt
    );

    // Test business requirement: 3-6 suggestions
    expect(result.suggestions.length).toBeGreaterThanOrEqual(3);
    expect(result.suggestions.length).toBeLessThanOrEqual(6);
  });
});
```

### **Pattern 2: Content Quality**

Test that suggestions are specific and actionable, not generic.

```typescript
describe(Content Quality, () => {
  it(should generate specific labels, not generic ones, async () => {
    const walletAssets = [
      { token: 0x..., symbol: USDC, amount: 500n * 10n ** 6n },
    ];

    const prompt = generateDepositPrompt({ walletAssets });

    const result: DepositSuggestion = await generateStructured(
      depositSuggestionSchema,
      prompt
    );

    // Test quality: Labels should be specific, not vague
    const hasGenericLabels = result.suggestions.some((s) =>
      [Edit,Change,Different,Other].includes(s.label)
    );
    expect(hasGenericLabels).toBe(false);

    // Labels should contain actual data
    const firstLabel = result.suggestions[0].label;
    expect(firstLabel.length).toBeGreaterThan(5); // Not just Edit
    expect(firstLabel).toMatch(/USDC|Strategy|Deposit|\d+/); // Contains specifics
  });

  it(should use actual token symbols from context, async () => {
    const walletAssets = [
      { token: 0x..., symbol: USDC, amount: 500n * 10n ** 6n },
    ];

    const prompt = generateDepositPrompt({ walletAssets });

    const result: DepositSuggestion = await generateStructured(
      depositSuggestionSchema,
      prompt
    );

    // Test: Suggestions reference actual user tokens
    const allSuggestionsText = result.suggestions
      .map((s) => `${s.label} ${s.text}`)
      .join( );

    expect(allSuggestionsText).toContain(USDC); // References real token
    expect(allSuggestionsText).toMatch(/\d+(\.\d+)?\s*USDC/); // Has amounts
  });
});
```

### **Pattern 3: Determinism**

Test that temperature 0 produces consistent results.

```typescript
import { testDeterminism } from ../utils/openrouter;

describe(Determinism, () => {
  it(should produce identical results with temperature 0, async () => {
    const params = {
      walletAssets: [
        { token: 0x..., symbol: USDC, amount: 1000n * 10n ** 6n },
      ],
      strategies: [{ id: 1, name: Safe Yield, risk: low }],
    };

    const prompt = generateDepositPrompt(params);

    // Use testDeterminism utility - generates same prompt twice
    const [result1, result2] = await testDeterminism(
      depositSuggestionSchema,
      prompt
    );

    // With temperature 0, should be identical
    expect(result1).toEqual(result2);
  });
});
```

### **Pattern 4: Integration with Real Data**

Test with actual service data to ensure end-to-end functionality.

```typescript
describe(Integration Tests, () => {
  it(should work with real wallet and strategy data, async () => {
    // Setup test user
    const userAddress = 0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb;
    const chainId = 42161; // Arbitrum

    // Fetch real data from services
    const service = runtime.getService<LevvaService>(
      LEVVA_SERVICE.LEVVA_COMMON
    );
    const assets = await service.getWalletAssets({ userAddress, chainId });
    const strategies = await service.getStrategies(chainId);

    // Generate suggestions with real data
    const prompt = generateDepositPrompt({
      walletAssets: assets,
      strategies,
    });

    const result: DepositSuggestion = await generateStructured(
      depositSuggestionSchema,
      prompt
    );

    // Verify suggestions work with real data
    expect(result.suggestions.length).toBeGreaterThan(0);

    // Verify suggestions reference actual user tokens
    const userTokenSymbols = assets.map((a) => a.symbol);
    const suggestionsReferencesUserTokens = result.suggestions.some((s) =>
      userTokenSymbols.some(
        (symbol) => s.text.includes(symbol) || s.label.includes(symbol)
      )
    );

    expect(suggestionsReferencesUserTokens).toBe(true);
  });
});
```

