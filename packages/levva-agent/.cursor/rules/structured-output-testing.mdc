## 🎯 **Testing Different Model Types**

### **Small Model (Default)**

Fast, simple structured generation using `OPENROUTER_MODELS.SMALL`.

```typescript
import { generateStructured, OPENROUTER_MODELS } from ../utils/openrouter;

describe(Simple Suggestions, () => {
  it(should generate suggestions quickly with small model, async () => {
    const startTime = Date.now();

    // Default uses OPENROUTER_MODELS.SMALL
    const result: DepositSuggestion = await generateStructured(
      depositSuggestionSchema,
      simplePrompt
    );

    const duration = Date.now() - startTime;

    // Should be fast with small model
    expect(duration).toBeLessThan(5000); // < 5 seconds
    expect(result.suggestions.length).toBeGreaterThanOrEqual(3);
  });
});
```

### **Large Model**

Complex analysis and reasoning using `OPENROUTER_MODELS.LARGE`.

```typescript
describe(Complex Analysis, () => {
  it(should provide detailed reasoning with large model, async () => {
    const analysisSchema = z.object({
      thought: z.string().describe(Detailed analysis reasoning),
      type: z.string(),
      known: z.record(z.any()),
      unknown: z.array(z.string()),
    });

    type Analysis = z.infer<typeof analysisSchema>;

    // Use large model for complex tasks
    const result: Analysis = await generateStructured(
      analysisSchema,
      complexAnalysisPrompt,
      { modelName: OPENROUTER_MODELS.LARGE }
    );

    // Verify detailed reasoning
    expect(result.thought.length).toBeGreaterThan(50);
    expect(result.thought).toMatch(/because|since|therefore|given/i);
  });
});
```

