  domain: LEVVA_ACTIONS;        // MANAGE_POSITIONS, SWAP_TOKENS, etc.
  userId: string;               // User identifier
  channelId: string;            // Channel identifier
  status: IntentStatus;         // ACTIVE, COMPLETED, CANCELLED, PAUSED
