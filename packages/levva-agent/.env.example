# Database Configuration
POSTGRES_URL=postgresql://user:password@localhost:5432/eliza

# Server Configuration
SERVER_PORT=3001
CENTRAL_MESSAGE_SERVER_URL=http://localhost:3001

# OpenRouter Configuration (Primary LLM Provider)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_SMALL_MODEL=openai/gpt-4o-mini
OPENROUTER_LARGE_MODEL=openai/gpt-4o-2024-08-06

# OpenAI Configuration (Embeddings)
OPENAI_EMBEDDING_API_KEY=your-openai-api-key-here
OPENAI_EMBEDDING_URL=https://api.openai.com/v1

# Kyber DEX Configuration
KYBER_CLIENT_ID=levvai

# Logging and Features
LOG_LEVEL=debug
LOAD_DOCS_ON_STARTUP=true
CTX_KNOWLEDGE_ENABLED=true

# Text Provider Configuration
TEXT_PROVIDER=openrouter
TEXT_MODEL=google/gemini-2.5-flash

# Optional: Eliza Server Authentication
#ELIZA_SERVER_AUTH_TOKEN=your-auth-token-here
