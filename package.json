{
  "name": "@elizaos/project-starter",
  "description": "Project starter for elizaOS",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "project",
    "elizaos"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@elizaos/cli": "^1.3.1",
    "@elizaos/core": "^1.3.1",
    "@elizaos/plugin-bootstrap": "^1.3.1",
    "@elizaos/plugin-knowledge": "^1.2.0",
    "@elizaos/plugin-openai": "^1.0.8",
    "@elizaos/plugin-openrouter": "^1.2.6",
    "@elizaos/plugin-sql": "^1.3.1",
    "fast-xml-parser": "^5.2.5",
    "patchright": "1.50.1",
    "viem": "^2.30.6",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@elizaos/api-client": "1.3.1",
    "@types/bun": "^1.2.21",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitest/coverage-v8": "2.1.5",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "evt": "^2.5.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "socket.io-client": "^4.8.1",
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "vitest": "3.1.4"
  },
  "scripts": {
    "start": "elizaos start",
    "dev": " elizaos dev",
    "debug": "bun --inspect-brk ./src/server.ts",
    "build": "tsup",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "test:unit": "vitest run --exclude='**/*.integration.test.ts'",
    "test:integration": "vitest run __tests__/*.integration.test.ts",
    "test:chat": "vitest run __tests__/chat-*.test.ts",
    "test:component": "vitest run",
    "test:e2e": "elizaos test",
    "test": "bun run test:unit && bun run test:e2e",
    "test:all": "bun run test:component && bun run test:e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "check": "bun run lint:check && bun run format:check && bun run test:unit",
    "fetch-tokens": "bun run scripts/fetch-tokens-by-chain.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "gitHead": "b165ad83e5f7a21bc1edbd83374ca087e3cd6b33",
  "patchedDependencies": {
    "@elizaos/plugin-bootstrap@1.3.1": "patches/@elizaos%2Fplugin-bootstrap@1.3.1.patch"
  }
}
